{
  "compilerOptions": {
    "target": "ESNext",
    "useDefineForClassFields": true,
    "lib": [
      "DOM",
      "DOM.Iterable",
      "ESNext"
    ],
    "allowJs": false,
    "skipLibCheck": true,
    "esModuleInterop": false,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "module": "ESNext",
    "moduleResolution": "Node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "incremental": true,
    "jsx": "react-jsx"
  },
  "include": [
    "."
  ],
  "exclude": [
    "node_modules",
    "dist",
    "tests/visual",
    "hop-in-express-customerApp",
    "englabs-inventory-app",
    "tests",
    "scripts",
    "playwright",
    "playwright-report"
  ]
}