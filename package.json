    "@testing-library/react": "^16.3.2",
    "@types/jsbarcode": "^3.11.4",
    "@types/jspdf": "^1.3.3",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.3",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^6.0.3",
    "@vitejs/plugin-react": "^4.2.1",
    "@wdio/appium-service": "^9.23.3",
    "@wdio/cli": "^9.23.3",
    "@wdio/local-runner": "^9.23.3",
    "@wdio/mocha-framework": "^9.23.3",
    "@wdio/spec-reporter": "^9.23.3",
    "appium": "^3.2.0",
    "appium-uiautomator2-driver": "^6.8.0",
    "autoprefixer": "^10.4.17",
    "concurrently": "^9.2.1",
    "dotenv": "^17.2.3",
    "husky": "^9.1.7",
    "javascript-obfuscator": "^5.3.0",
    "jsdom": "^27.4.0",
    "lint-staged": "^16.2.7",
    "postcss": "^8.4.35",
    "rollup-plugin-obfuscator": "^1.1.0",
    "supertest": "^7.2.2",
    "tailwindcss": "^3.4.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vite": "^5.1.4",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.0.18",
    "webdriverio": "^9.23.3"
  }
}