{
  "name": "englabs-inventory-management",
  "private": true,
  "version": "3.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "start": "concurrently \"npm run serve\" \"npm run dev\"",
    "build": "tsc --incremental && vite build && npx cap sync",
    "build:dev": "tsc --incremental && vite build --mode development",
    "build:staging": "tsc --incremental && vite build --mode staging",
    "build:local": "tsc --incremental && vite build --mode staging && npx cap sync",
    "build:copy": "echo 'Skipping client build'",
    "build:copy:win": "echo 'Skipping client build'",
    "preview": "vite preview",
    "preview:staging": "vite preview --mode staging",
    "serve": "node server.js",
    "android": "npm run build:local && npx cap sync && npx cap open android",
    "info": "echo. && echo --------------------------------------------------- && echo Hello, && echo Install your work app: && echo https://englabs-enterprise.web.app && echo. && echo Login: && echo Username: admin@englabs.co.uk && echo Password: xxxx && echo --------------------------------------------------- && echo.",
    "seed:dev": "node scripts/seed_database.js development",
    "seed:staging": "node scripts/seed_database.js staging",
    "seed:prod": "node scripts/seed_database.js production",
    "clone:prod:dev": "node scripts/clone_prod_data.js development",
    "clone:prod:staging": "node scripts/clone_prod_data.js staging",
    "deploy": "npx firebase-tools deploy --only hosting",
    "make-docs": "node scripts/create_doc.js",
    "git-push": "scripts\\easy_push.bat",
    "test": "node node_modules/vitest/vitest.mjs",
    "test:native": "node node_modules/@wdio/cli/bin/wdio.js run wdio.conf.ts",
    "test:visual": "npx playwright test tests/visual",
    "test:percy": "percy exec -- npx playwright test tests/visual",
    "test:security": "npx playwright test tests/security",
    "test:chaos": "npx playwright test tests/system/chaos.spec.ts",
    "test:mutation": "stryker run",
    "test:coverage": "node scripts/coverage_analyzer.js",
    "test:audit": "node scripts/autonomous_runner.js",
    "test:agentic": "node node_modules/vitest/vitest.mjs run tests/unit/agentic_core.unit.test.ts tests/functional/CommandCenter.functional.test.tsx tests/smoke/agentic_ecosystem.smoke.test.ts",
    "release:autonomous": "node scripts/antigravity_orchestrator.js",
    "prepare": "husky"
  },
  "dependencies": {
    "@capacitor/android": "^8.0.1",
    "@capacitor/camera": "^8.0.0",
    "@capacitor/cli": "^8.0.1",
    "@capacitor/core": "^8.0.1",
    "@capacitor/filesystem": "^8.0.0",
    "@capacitor/ios": "^8.0.1",
    "@capacitor/share": "^8.0.0",
    "@google/genai": "^1.34.0",
    "@google/generative-ai": "^0.24.1",
    "@react-native-community/netinfo": "^11.5.2",
    "@tensorflow-models/coco-ssd": "^2.2.3",
    "@tensorflow/tfjs": "^4.22.0",
    "@tensorflow/tfjs-backend-cpu": "^4.22.0",
    "@tensorflow/tfjs-backend-webgl": "^4.22.0",
    "barcode.js": "^0.1.25",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "driver.js": "^1.4.0",
    "express": "^5.2.1",
    "firebase": "^10.8.0",
    "framer-motion": "^12.26.2",
    "html2canvas": "^1.4.1",
    "html5-qrcode": "^2.3.8",
    "jimp": "^1.6.0",
    "jsbarcode": "^3.12.3",
    "jspdf": "^4.1.0",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.562.0",
    "moment-timezone": "^0.6.0",
    "multer": "^2.0.2",
    "onnxruntime-web": "^1.20.0",
    "pdf-parse": "^2.4.5",
    "pdfkit": "^0.17.2",
    "playwright": "^1.58.2",
    "qrcode": "^1.5.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-is": "19.2.4",
    "react-native-safe-area-context": "^5.6.2",
    "react-native-web": "^0.21.2",
    "recharts": "^3.6.0",
    "rxjs": "^7.8.2",
    "simple-git": "^3.30.0",
    "tailwind-merge": "^3.4.0",
    "xhr2": "^0.2.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@percy/cli": "^1.31.8",
    "@percy/playwright": "^1.0.10",
    "@playwright/test": "^1.58.2",
    "@stryker-mutator/core": "^9.5.1",
    "@stryker-mutator/typescript-checker": "^9.5.1",
    "@stryker-mutator/vitest-runner": "^9.5.1",
